rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Definitions & Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.createdAt is timestamp;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['fullName', 'email', 'phone', 'date', 'status', 'createdAt']) &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.date is string && data.date.size() <= 20 &&
             data.status in ['pending', 'confirmed', 'completed', 'cancelled'] &&
             data.createdAt is timestamp &&
             (data.keys().hasAny(['userId']) ? (data.userId is string && data.userId.size() <= 128) : true);
    }

    // 3. Collection Rules
    
    // User Profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']) &&
                      (incoming().keys().hasAny(['updatedAt']) ? incoming().updatedAt == request.time : true);
    }

    // Bookings
    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isValidBooking(incoming()) && 
                      (incoming().keys().hasAny(['userId']) ? incoming().userId == request.auth.uid : true) &&
                      incoming().createdAt == request.time;
      
      allow update: if false; // Only admin or system can update status
      allow delete: if false;
    }
  }
}
